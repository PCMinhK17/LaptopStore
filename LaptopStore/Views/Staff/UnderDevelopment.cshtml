@{
    ViewData["Title"] = "Đang phát triển";
    ViewData["Subtitle"] = "Tính năng sẽ sớm ra mắt";
    Layout = "~/Views/Shared/_StaffLayout.cshtml";
    var featureName = ViewData["Feature"]?.ToString() ?? "Tính năng này";
}

<div class="under-development-container">
    <div class="under-development-card">
        <div class="ud-icon-wrapper">
            <div class="ud-icon-bg"></div>
            <div class="ud-icon">
                <i class="fas fa-tools"></i>
            </div>
            <div class="ud-particles">
                <span></span><span></span><span></span><span></span><span></span><span></span>
            </div>
        </div>
        
        <h2 class="ud-title">Đang phát triển</h2>
        <p class="ud-description">
            <strong>@featureName</strong> hiện đang được phát triển và sẽ sớm ra mắt.
            <br>Chúng tôi đang nỗ lực để mang đến trải nghiệm tốt nhất cho bạn.
        </p>
        
        <div class="ud-features">
            <div class="ud-feature-item">
                <div class="ud-feature-icon">
                    <i class="fas fa-rocket"></i>
                </div>
                <div>
                    <div class="ud-feature-title">Đang xây dựng</div>
                    <div class="ud-feature-desc">Tính năng đang trong quá trình phát triển</div>
                </div>
            </div>
            <div class="ud-feature-item">
                <div class="ud-feature-icon">
                    <i class="fas fa-shield-alt"></i>
                </div>
                <div>
                    <div class="ud-feature-title">Kiểm thử chất lượng</div>
                    <div class="ud-feature-desc">Đảm bảo ổn định trước khi phát hành</div>
                </div>
            </div>
            <div class="ud-feature-item">
                <div class="ud-feature-icon">
                    <i class="fas fa-bell"></i>
                </div>
                <div>
                    <div class="ud-feature-title">Thông báo khi sẵn sàng</div>
                    <div class="ud-feature-desc">Bạn sẽ được thông báo khi tính năng hoàn thành</div>
                </div>
            </div>
        </div>

        <div class="ud-actions">
            <a href="@Url.Action("Index", "StaffDashboard")" class="btn btn-primary">
                <i class="fas fa-arrow-left me-2"></i>
                Quay về Dashboard
            </a>
        </div>
    </div>
</div>

<style>
    .under-development-container {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 200px);
        padding: 2rem;
    }

    .under-development-card {
        text-align: center;
        max-width: 560px;
        padding: 3rem 2rem;
        background: var(--card-bg);
        border-radius: var(--radius-xl);
        border: 1px solid var(--border-color);
        box-shadow: var(--shadow-lg);
        animation: fadeInUp 0.6s ease-out;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .ud-icon-wrapper {
        position: relative;
        display: inline-block;
        margin-bottom: 2rem;
    }

    .ud-icon-bg {
        position: absolute;
        inset: -15px;
        border-radius: 50%;
        background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(139, 92, 246, 0.1));
        animation: pulse-ring 2s ease-in-out infinite;
    }

    @@keyframes pulse-ring {
        0%, 100% { transform: scale(1); opacity: 1; }
        50% { transform: scale(1.15); opacity: 0.7; }
    }

    .ud-icon {
        position: relative;
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.5rem;
        color: white;
        box-shadow: 0 10px 40px rgba(99, 102, 241, 0.3);
        animation: float 3s ease-in-out infinite;
    }

    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-8px); }
    }

    .ud-particles span {
        position: absolute;
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #6366f1;
        opacity: 0.4;
        animation: particle-float 3s ease-in-out infinite;
    }

    .ud-particles span:nth-child(1) { top: -10px; left: 20px; animation-delay: 0s; }
    .ud-particles span:nth-child(2) { top: 10px; right: -15px; animation-delay: 0.5s; }
    .ud-particles span:nth-child(3) { bottom: -10px; right: 15px; animation-delay: 1s; }
    .ud-particles span:nth-child(4) { bottom: 5px; left: -12px; animation-delay: 1.5s; }
    .ud-particles span:nth-child(5) { top: 50%; left: -18px; animation-delay: 0.8s; background: #8b5cf6; }
    .ud-particles span:nth-child(6) { top: 50%; right: -18px; animation-delay: 1.2s; background: #8b5cf6; }

    @@keyframes particle-float {
        0%, 100% { transform: translateY(0) scale(1); opacity: 0.4; }
        50% { transform: translateY(-10px) scale(1.5); opacity: 0.8; }
    }

    .ud-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 0.75rem;
    }

    .ud-description {
        color: var(--text-secondary);
        font-size: 0.95rem;
        line-height: 1.7;
        margin-bottom: 2rem;
    }

    .ud-features {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 2rem;
        text-align: left;
    }

    .ud-feature-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        border-radius: var(--radius-lg);
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        transition: all 0.3s ease;
    }

    .ud-feature-item:hover {
        transform: translateX(4px);
        border-color: var(--primary-200);
        background: var(--primary-50);
    }

    .ud-feature-icon {
        width: 42px;
        height: 42px;
        border-radius: var(--radius-md);
        background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(139, 92, 246, 0.15));
        display: flex;
        align-items: center;
        justify-content: center;
        color: #6366f1;
        font-size: 1rem;
        flex-shrink: 0;
    }

    .ud-feature-title {
        font-weight: 600;
        font-size: 0.9rem;
        color: var(--text-primary);
    }

    .ud-feature-desc {
        font-size: 0.8rem;
        color: var(--text-muted);
    }

    .ud-actions .btn-primary {
        padding: 0.75rem 2rem;
        border-radius: var(--radius-lg);
        font-weight: 600;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border: none;
        transition: all 0.3s ease;
    }

    .ud-actions .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(99, 102, 241, 0.4);
    }
</style>
