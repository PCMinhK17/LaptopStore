@model List<LaptopStore.Models.Order>

@{
    string current = (ViewBag.CurrentStatus ?? "all").ToString().ToLower();
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<style>
    body {
        background-color: #f5f6f7;
    }

    .profile-sidebar .list-group-item {
        border: none;
        cursor: pointer;
        font-size: 14px;
    }

        .profile-sidebar .list-group-item.active {
            background-color: #fff0f0;
            color: #d70018;
            font-weight: 600;
        }

    .profile-card {
        border-radius: 10px;
    }

    .order-card {
        border: 1px solid #eee;
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 16px;
        background: #fff;
        transition: 0.2s;
    }

        .order-card:hover {
            transform: translateY(-3px);
        }

    .order-total {
        color: #d70018;
        font-weight: 700;
        font-size: 18px;
    }

    .status-pending {
        color: #ff9800;
    }

    .status-confirmed {
        color: #2196f3;
    }

    .status-shipping {
        color: #2196f3;
    }

    .status-completed {
        color: #4caf50;
    }

    .status-cancelled {
        color: #9e9e9e;
    }
</style>

<div class="container mt-4">
    <div class="row">

        <!-- LEFT SIDEBAR -->
        <div class="col-md-3">
            <div class="card profile-sidebar shadow-sm">
                <div class="card-body text-center">
                    <h6 class="fw-bold mb-0">@ViewBag.User.FullName</h6>
                    <small class="text-muted">@ViewBag.User.PhoneNumber</small>
                </div>

                <ul class="list-group list-group-flush">
                    <a href="/User/Profile"
                       class="list-group-item">
                        Thông tin cá nhân
                    </a>

                    <a href="/Order/OrderHistory"
                       class="list-group-item active">
                        Đơn hàng của tôi
                    </a>

                    <li class="list-group-item">
                        Thông báo của tôi
                    </li>
                </ul>
            </div>
        </div>

        <!-- RIGHT CONTENT -->
        <div class="col-md-9">

            <div class="card profile-card shadow-sm p-4">

                <h4 class="fw-bold text-danger mb-4">
                    <i class="bi bi-bag-check"></i> Đơn hàng của tôi
                </h4>

                <!-- Tabs -->
                <ul class="nav nav-tabs mb-4">
                    <li class="nav-item">
                        <a class="nav-link @(current == "all" ? "active" : "")"
                           href="/Order/OrderHistory?status=all">Tất cả</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(current == "pending" ? "active" : "")"
                           href="/Order/OrderHistory?status=pending">
                            Đang xử lý
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(current == "confirmed" ? "active" : "")"
                           href="/Order/OrderHistory?status=confirmed">
                            Đã xác nhận
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(current == "shipping" ? "active" : "")"
                           href="/Order/OrderHistory?status=shipping">
                            Đang giao
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(current == "completed" ? "active" : "")"
                           href="/Order/OrderHistory?status=completed">
                            Hoàn thành
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(current == "cancelled" ? "active" : "")"
                           href="/Order/OrderHistory?status=cancelled">
                            Đã huỷ
                        </a>
                    </li>
                </ul>

                @if (!Model.Any())
                {
                    <div class="text-center text-muted py-5">
                        <i class="fa-solid fa-box-open fa-2x mb-2"></i>
                        <p>Bạn chưa có đơn hàng nào</p>
                    </div>
                }
                else
                {
                    @foreach (var order in Model)
                    {
                        <div class="order-card shadow-sm" id="order-@order.Id">

                            <div class="d-flex justify-content-between align-items-center"
                                 onclick="toggleDetail(@order.Id)"
                                 style="cursor:pointer;">

                                <div>
                                    <h6 class="fw-bold text-danger mb-1">
                                        Đơn hàng #@order.Id
                                    </h6>
                                    <small class="text-muted">
                                        @order.CreatedAt?.ToString("dd/MM/yyyy HH:mm")
                                    </small>
                                    <div class="order-total mt-2">
                                        @order.TotalMoney.ToString("N0") ₫
                                    </div>
                                </div>

                                <div class="text-end">
                                    <span class="order-status status-@order.Status?.ToLower()">
                                        @order.Status
                                    </span>

                                    @{
                                        var status = order.Status?.Trim().ToLower();
                                    }

                                    @if (status == "pending" || status == "confirmed")
                                    {
                                        <button class="btn btn-sm btn-outline-danger mt-2"
                                                onclick="cancelOrder(event,@order.Id)">
                                            Huỷ đơn
                                        </button>
                                    }
                                </div>
                            </div>

                            <!-- DETAIL -->
                            <div class="mt-3 order-detail"
                                 id="detail-@order.Id"
                                 style="display:none">
                                <hr />
                                <p><strong>Người nhận:</strong> @order.FullName</p>
                                <p><strong>SĐT:</strong> @order.PhoneNumber</p>
                                <p><strong>Địa chỉ:</strong> @order.Address</p>
                            </div>

                        </div>
                    }
                }

            </div>
        </div>

    </div>
</div>
