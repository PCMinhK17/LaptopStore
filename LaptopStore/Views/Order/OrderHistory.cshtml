@model List<LaptopStore.Models.Order>

@{
    string current = (ViewBag.CurrentStatus ?? "all").ToString().ToLower();
}
<link rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<style>
    :root {
        --fpt-red: #d70018;
        --fpt-gray: #f5f5f5;
    }

    .fpt-tabs .nav-link {
        color: #333;
        font-weight: 500;
    }

        .fpt-tabs .nav-link.active {
            color: var(--fpt-red);
            border-bottom: 2px solid var(--fpt-red);
        }

    .order-card {
        border: 1px solid #eee;
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 16px;
        background: #fff;
    }

    .order-status {
        font-weight: 600;
        font-size: 14px;
    }

    .status-pending {
        color: #ff9800;
    }

    .status-shipping {
        color: #2196f3;
    }

    .status-completed {
        color: #4caf50;
    }

    .status-cancelled {
        color: #9e9e9e;
    }

    .order-total {
        color: var(--fpt-red);
        font-weight: 700;
        font-size: 18px;
    }

    .btn-fpt {
        border: 1px solid var(--fpt-red);
        color: var(--fpt-red);
        font-weight: 500;
    }

        .btn-fpt:hover {
            background: var(--fpt-red);
            color: #fff;
        }

    .order-card {
        transition: 0.2s ease-in-out;
    }

        .order-card:hover {
            transform: translateY(-3px);
        }

    .badge {
        padding: 6px 12px;
        font-size: 13px;
    }

    .btn-outline-danger {
        border-radius: 20px;
        font-weight: 500;
    }
</style>




<h4 class="fw-bold text-danger mb-4">
    <i class="bi bi-bag-check"></i> Đơn hàng của tôi
</h4>

    <!-- Tabs -->
    <ul class="nav nav-tabs fpt-tabs mb-4">
        <li class="nav-item">
            <a class="nav-link @(current=="all"?"active":"")"
               href="/Order/OrderHistory?status=all">
                Tất cả
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(current=="pending"?"active":"")"
               href="/Order/OrderHistory?status=pending">
                <i class="fa-solid fa-clock"></i> Đang xử lý
            </a>
        </li>
    <li class="nav-item">
        <a class="nav-link @(current == "confirmed" ? "active" : "")"
           href="/Order/OrderHistory?status=confirmed">
            <i class="fa-solid fa-check"></i> Đã xác nhận
        </a>
    </li>

        <li class="nav-item">
            <a class="nav-link @(current=="shipping"?"active":"")"
               href="/Order/OrderHistory?status=shipping">
                <i class="fa-solid fa-truck"></i> Đang giao
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(current=="completed"?"active":"")"
               href="/Order/OrderHistory?status=completed">
            <i class="fa-solid fa-circle-check"></i> Hoàn thành
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(current=="cancelled"?"active":"")"
               href="/Order/OrderHistory?status=cancelled">
                <i class="fa-solid fa-xmark"></i> Đã huỷ
            </a>
        </li>
    </ul>

    @if (!Model.Any())
    {
        <div class="text-center text-muted py-5">
            <i class="fa-solid fa-box-open fa-2x mb-2"></i>
            <p>Bạn chưa có đơn hàng nào</p>
        </div>
    }
    else
    {
        @foreach (var order in Model)
{
    <div class="order-card shadow-sm" id="order-@order.Id">

        <div class="d-flex justify-content-between align-items-center"
             onclick="toggleDetail(@order.Id)"
             style="cursor:pointer;">

            <div>
                <h6 class="fw-bold text-danger mb-1">
                    Đơn hàng #@order.Id
                </h6>
                <small class="text-muted">
                    @(order.CreatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "")
                </small>
                <div class="order-total mt-2">
                    @order.TotalMoney.ToString("N0") ₫
                </div>
            </div>

            <div class="text-end">

                <span class="order-status status-@order.Status?.ToLower()">
                    @order.Status
                </span>

                    @{
                        var status = order.Status?.Trim().ToLower();
                    }

                    @if (status == "pending" || status == "confirmed")
                    {
                        <button class="btn btn-sm btn-outline-danger mt-2"
                                onclick="cancelOrder(event,@order.Id)">
                            <i class="fa-solid fa-xmark"></i> Huỷ đơn
                        </button>
                    }

            </div>
        </div>

            <!-- DETAIL -->
            <div class="mt-3 order-detail" id="detail-@order.Id" style="display:none">
                <hr />

                <p><strong>Người nhận:</strong> @order.FullName</p>
                <p><strong>SĐT:</strong> @order.PhoneNumber</p>
                <p><strong>Địa chỉ:</strong> @order.Address</p>
                <p><strong>Thanh toán:</strong> @order.PaymentMethod</p>

                <div class="mt-3">
                    <strong>Sản phẩm:</strong>

                    @foreach (var item in order.OrderDetails)
                    {
                        <div class="d-flex justify-content-between border-bottom py-2">
                            <div>
                                <strong>@item.Product?.Name</strong><br />
                                SL: @item.Quantity
                            </div>

                            <div class="text-end">
                                @item.Price.ToString("N0") ₫ <br />
                                <span class="text-danger fw-bold">
                                    @((item.TotalPrice ?? (item.Price * item.Quantity)).ToString("N0")) ₫
                                </span>
                            </div>
                        </div>
                    }
                </div>
            </div>


    </div>
}
    }
<div class="position-fixed bottom-0 end-0 p-3" style="z-index:9999">
    <div id="cancelToast" class="toast align-items-center text-white bg-success border-0">
        <div class="d-flex">
            <div class="toast-body">
                <i class="fa-solid fa-circle-check"></i>
                Huỷ đơn thành công!
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto"
                    data-bs-dismiss="toast"></button>
        </div>
    </div>
</div>

<script>
    function toggleDetail(id) {
        let el = document.getElementById("detail-" + id);
        el.style.display = (el.style.display === "none") ? "block" : "none";
    }

    function cancelOrder(event, id) {
        event.stopPropagation();

        if (!confirm("Bạn có chắc muốn huỷ đơn này?")) return;

        fetch('/Order/Cancel', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ id: id })
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {

                let card = document.getElementById("order-" + id);

                // update status UI
                card.querySelector(".order-status").innerHTML = "Cancelled";
                card.querySelector(".order-status").className =
                    "order-status status-cancelled";

                // remove cancel button
                let btn = card.querySelector(".btn-outline-danger");
                if (btn) btn.remove();

                // toast
                let toast = new bootstrap.Toast(
                    document.getElementById('cancelToast'));
                toast.show();
            }
        });
    }
</script>
