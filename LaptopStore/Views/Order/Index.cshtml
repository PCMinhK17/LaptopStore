@model List<LaptopStore.Models.Order>
@{
    ViewData["Title"] = "Danh sách đơn hàng";
}

<div class="container mt-4 mb-5">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Danh sách đơn hàng</h4>
        </div>
        <div class="card-body">
            @if (Model == null || Model.Count == 0)
            {
                <div class="alert alert-info" role="alert">
                    Không có đơn hàng nào.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Mã đơn hàng</th>
                                <th>Khách hàng</th>
                                <th>Ngày đặt</th>
                                <th>Tổng tiền</th>
                                <th>Trạng thái</th>
                                <th>Thanh toán</th>
                                <th>Hành động</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var order in Model)
                            {
                                <tr>
                                    <td><strong>#@order.Id</strong></td>
                                    <td>
                                        @order.FullName
                                        <br />
                                        <small class="text-muted">@order.PhoneNumber</small>
                                    </td>
                                    <td>@order.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="fw-bold">@order.TotalMoney.ToString("N0") đ</td>
                                    <td>
                                        @{
                                            var statusBadgeClass = order.Status switch
                                            {
                                                "pending" => "badge bg-warning text-dark",
                                                "confirmed" => "badge bg-info",
                                                "shipped" => "badge bg-primary",
                                                "delivered" => "badge bg-success",
                                                "cancelled" => "badge bg-danger",
                                                _ => "badge bg-secondary"
                                            };
                                            var statusText = order.Status switch
                                            {
                                                "pending" => "Chờ xác nhận",
                                                "confirmed" => "Đã xác nhận",
                                                "shipped" => "Đã giao cho vận chuyển",
                                                "delivered" => "Đã giao",
                                                "cancelled" => "Đã hủy",
                                                "completed" => "Hoàn thành",
                                                "shipping" => "Đang giao hàng",
                                                _ => order.Status
                                            };
                                        }
                                        <span class="@statusBadgeClass">@statusText</span>
                                    </td>
                                    <td>
                                        @{
                                            var paymentBadgeClass = order.PaymentStatus switch
                                            {
                                                "unpaid" => "badge bg-danger",
                                                "paid" => "badge bg-success",
                                                "refunded" => "badge bg-secondary",
                                                _ => "badge bg-secondary"
                                            };
                                            var paymentText = order.PaymentStatus switch
                                            {
                                                "unpaid" => "Chưa thanh toán",
                                                "paid" => "Đã thanh toán",
                                                "refunded" => "Đã hoàn tiền",
                                                _ => order.PaymentStatus
                                            };
                                        }
                                        <span class="@paymentBadgeClass">@paymentText</span>
                                    </td>
                                    <td>
                                        <a href="@Url.Action("Details", "Order", new { id = order.Id })" class="btn btn-sm btn-info">
                                            <i class="bi bi-eye"></i> Chi tiết
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: #f5f5f5;
    }
</style>
