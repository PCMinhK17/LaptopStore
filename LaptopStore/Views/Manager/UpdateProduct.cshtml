@model UpdateProductRequest;

<div class="container mt-4 mb-5">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Cập nhật sản phẩm</h4>
            <a asp-controller="ProductManagement" asp-action="ProductDetails" asp-route-id="@Model.Id" class="btn btn-outline-light btn-sm">
                ← Quay lại chi tiết
            </a>
        </div>
        <div class="card-body">
            <form asp-controller="ProductManagement" asp-action="UpdateProduct" method="post" enctype="multipart/form-data">
                <input asp-for="Id" type="hidden" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-bold">Tên sản phẩm</label>
                        <input asp-for="Name" class="form-control" placeholder="Nhập tên máy tính..." />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Sku" class="form-label fw-bold">Mã SKU</label>
                        <input asp-for="Sku" class="form-control" placeholder="Ví dụ: LPT-A102" />
                        <span asp-validation-for="Sku" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="BrandId" class="form-label fw-bold">Thương hiệu</label>
                        <select asp-for="BrandId" class="form-select">
                            <option value="" selected disabled>-- Chọn thương hiệu --</option>
                            @foreach (var brand in ViewBag.Brands)
                            {
                                <option value="@brand.Id">@brand.Name</option>
                            }
                        </select>
                        <span asp-validation-for="BrandId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="CategoryId" class="form-label fw-bold">Phân loại</label>
                        <select asp-for="CategoryId" class="form-select">
                            <option value="" selected disabled>-- Chọn phân loại --</option>
                            @foreach (var category in ViewBag.Categories)
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        </select>
                        <span asp-validation-for="CategoryId" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Price" class="form-label fw-bold">Giá bán (VNĐ)</label>
                        <input asp-for="Price" class="form-control" />
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Cpu" class="form-label fw-bold">CPU</label>
                        <input asp-for="Cpu" class="form-control" placeholder="i7-13700H..." />
                        <span asp-validation-for="Cpu" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Ram" class="form-label fw-bold">RAM</label>
                        <input asp-for="Ram" class="form-control" placeholder="16GB DDR5..." />
                        <span asp-validation-for="Ram" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="HardDrive" class="form-label fw-bold">Ổ cứng</label>
                        <input asp-for="HardDrive" class="form-control" placeholder="SSD 512GB..." />
                        <span asp-validation-for="HardDrive" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Gpu" class="form-label fw-bold">GPU</label>
                        <input asp-for="Gpu" class="form-control" placeholder="RTX 4060..." />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="ScreenSize" class="form-label fw-bold">Màn hình</label>
                        <input asp-for="ScreenSize" class="form-control" placeholder="15.6 inch..." />
                        <span asp-validation-for="ScreenSize" class="text-danger small"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Weight" class="form-label fw-bold">Trọng lượng (kg)</label>
                        <input asp-for="Weight" class="form-control" />
                        <span asp-validation-for="Weight" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="ShortDescription" class="form-label fw-bold">Tóm tắt ngắn</label>
                        <textarea asp-for="ShortDescription" class="form-control" rows="3"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Description" class="form-label fw-bold">Mô tả chi tiết</label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="col-md-6 d-flex align-items-end">
                        <div class="form-check form-switch">
                            <input asp-for="IsActive" class="form-check-input" type="checkbox" role="switch" />
                            <label class="form-check-label" asp-for="IsActive">Hiển thị sản phẩm</label>
                        </div>
                    </div>

                    <div class="col-12 mt-4 text-end">
                        <a asp-controller="ProductManagement" asp-action="ProductDetails" asp-route-id="@Model.Id" class="btn btn-outline-secondary me-2">Hủy</a>
                        <button type="submit" class="btn btn-primary px-5">Lưu thay đổi</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

