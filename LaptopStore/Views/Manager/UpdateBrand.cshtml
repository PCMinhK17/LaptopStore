@model LaptopStore.DTOs.BrandDTOs.UpdateBrandRequest

@{
    ViewData["Title"] = "Quản lý thương hiệu";
    ViewData["Subtitle"] = "Cập nhập thương hiệu";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4 mb-5">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Cập nhật thương hiệu</h4>
            <a asp-controller="BrandManagement"
               asp-action="BrandDetails"
               asp-route-id="@Model.Id"
               class="btn btn-outline-light btn-sm">
                ← Quay lại chi tiết
            </a>
        </div>

        <div class="card-body">
            <form asp-controller="BrandManagement"
                  asp-action="UpdateBrand"
                  method="post"
                  enctype="multipart/form-data">

                <input asp-for="Id" type="hidden" />

                <div class="row g-3">

                    <div class="col-md-6">
                        <label asp-for="Name" class="form-label fw-bold">
                            Tên thương hiệu <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Name" class="form-control"
                               placeholder="Ví dụ: Dell, Asus..." />
                        <span asp-validation-for="Name"
                              class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Origin" class="form-label fw-bold">
                            Quốc gia<span class="text-danger">*</span>
                        </label>
                        <input asp-for="Origin" class="form-control"
                               placeholder="USA, Taiwan..." />
                        <span asp-validation-for="Origin"
                              class="text-danger small"></span>
                    </div>

                   
                    <div class="col-md-6">
                        <label class="form-label fw-bold">
                            Logo mới (nếu muốn thay đổi)
                        </label>
                        <input asp-for="LogoFile"
                               type="file"
                               class="form-control"
                               accept="image/*" />
                    </div>

                  
                    <div class="col-12 mt-4 text-end">
                        <a asp-controller="BrandManagement"
                           asp-action="BrandDetails"
                           asp-route-id="@Model.Id"
                           class="btn btn-outline-secondary me-2">
                            Hủy
                        </a>

                        <button type="submit"
                                class="btn btn-primary px-5">
                            Lưu thay đổi
                        </button>
                    </div>

                </div>
            </form>
        </div>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}