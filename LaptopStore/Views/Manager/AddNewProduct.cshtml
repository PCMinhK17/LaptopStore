@model AddNewProductRequest;

<div class="container-fluid">
    <div class="row">

        <nav class="col-md-3 col-lg-2 d-md-block bg-light sidebar pt-3 border-end" style="min-height: 100vh;">
            <partial name="_AdminNav" />
        </nav>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 pt-3 mb-5">

            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
                    <h4 class="mb-0">Thêm sản phẩm mới</h4>
                    <a asp-controller="ProductManagement" asp-action="Index" class="btn btn-sm btn-light text-primary fw-bold">
                        <i class="bi bi-arrow-left"></i> Trở về danh sách
                    </a>
                </div>
                <div class="card-body bg-light rounded-bottom">

                    <form asp-controller="ProductManagement" asp-action="AddNewProduct" method="post" enctype="multipart/form-data" class="bg-white p-4 rounded border">

                        <div class="row g-4">
                            <div class="col-md-6">
                                <label asp-for="Name" class="form-label fw-bold">Tên sản phẩm <span class="text-danger">*</span></label>
                                <input asp-for="Name" class="form-control" placeholder="Nhập tên máy tính..." />
                                <span asp-validation-for="Name" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Sku" class="form-label fw-bold">Mã SKU <span class="text-danger">*</span></label>
                                <input asp-for="Sku" class="form-control" placeholder="Ví dụ: LPT-A102" />
                                <span asp-validation-for="Sku" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="BrandId" class="form-label fw-bold">Thương hiệu</label>
                                <select asp-for="BrandId" class="form-select">
                                    <option value="" selected disabled>-- Chọn thương hiệu --</option>
                                    @if (ViewBag.Brands != null)
                                    {
                                        foreach (var brand in ViewBag.Brands)
                                        {
                                            <option value="@brand.Id">@brand.Name</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="BrandId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="CategoryId" class="form-label fw-bold">Phân loại</label>
                                <select asp-for="CategoryId" class="form-select">
                                    <option value="" selected disabled>-- Chọn phân loại --</option>
                                    @if (ViewBag.Categories != null)
                                    {
                                        foreach (var category in ViewBag.Categories)
                                        {
                                            <option value="@category.Id">@category.Name</option>
                                        }
                                    }
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger small"></span>
                            </div>

                            <div class="col-md-12">
                                <label asp-for="Price" class="form-label fw-bold">Giá bán (VNĐ) <span class="text-danger">*</span></label>
                                <input asp-for="Price" class="form-control form-control-lg text-primary fw-bold" type="number" placeholder="0" />
                                <span asp-validation-for="Price" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Cpu" class="form-label fw-bold">CPU <span class="text-danger">*</span></label>
                                <input asp-for="Cpu" class="form-control" placeholder="i7-13700H..." />
                                <span asp-validation-for="Cpu" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Ram" class="form-label fw-bold">RAM <span class="text-danger">*</span></label>
                                <input asp-for="Ram" class="form-control" placeholder="16GB DDR5..." />
                                <span asp-validation-for="Ram" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="HardDrive" class="form-label fw-bold">Ổ cứng <span class="text-danger">*</span></label>
                                <input asp-for="HardDrive" class="form-control" placeholder="SSD 512GB..." />
                                <span asp-validation-for="HardDrive" class="text-danger small"></span>
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Gpu" class="form-label fw-bold">Card đồ họa</label>
                                <input asp-for="Gpu" class="form-control" placeholder="RTX 4060..." />
                            </div>
                            <div class="col-md-4">
                                <label asp-for="ScreenSize" class="form-label fw-bold">Kích cỡ màn hình <span class="text-danger">*</span></label>
                                <input asp-for="ScreenSize" class="form-control" placeholder="15.6 inch..." />
                                <span asp-validation-for="ScreenSize" class="text-danger small"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Weight" class="form-label fw-bold">Trọng lượng (kg) <span class="text-danger">*</span></label>
                                <input asp-for="Weight" class="form-control" type="number" step="0.01" placeholder="1.5" />
                                <span asp-validation-for="Weight" class="text-danger small"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="ShortDescription" class="form-label fw-bold">Tóm tắt ngắn</label>
                                <textarea asp-for="ShortDescription" class="form-control" rows="4" placeholder="Nhập tóm tắt sản phẩm..."></textarea>
                                <span asp-validation-for="ShortDescription" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Description" class="form-label fw-bold">Mô tả chi tiết</label>
                                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả chi tiết..."></textarea>
                            </div>

                            <div class="col-md-12">
                                <label class="form-label fw-bold">Hình ảnh sản phẩm</label>
                                <div class="input-group">
                                    <input asp-for="ImageFile" type="file" class="form-control" id="uploadImg" accept="image/*">
                                    <label class="input-group-text bg-primary text-white border-primary" for="uploadImg">Tải lên</label>
                                </div>
                            </div>

                            <div class="col-12 mt-5 pt-3 border-top text-end">
                                <a asp-controller="ProductManagement" asp-action="Index" class="btn btn-outline-secondary me-2 px-4">Hủy</a>
                                <button type="submit" class="btn btn-primary px-5 fw-bold">Lưu sản phẩm</button>
                            </div>
                        </div>

                    </form>
                </div>
            </div>

        </main>
    </div>
</div>

