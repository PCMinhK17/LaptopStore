@model List<ImportReceipt>
@using LaptopStore.Models

@{
    ViewData["Title"] = "Đơn nhập hàng";

}
<html>
<body>
    <div>
        <h2 style="display:inline-block">Các đơn nhập hàng</h2>
        <a asp-controller="StockManagement" asp-action="AddNewStockInOrder" style="float:right; margin-top:10px;">Tạo đơn nhập hàng</a>
    </div>
    @if (Model == null || Model.Count == 0)
    {
        <p>Không có sản phẩm nào trong hệ thống.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Nhà cung cấp</th>
                    <th>Giá</th>
                    <th>Ngày</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var stock in Model)
                {
                    <tr>
                        <td><a asp-controller="StockManagement" asp-action="StockDetails" asp-route-id="@stock.Id">@stock.SupplierName</a></td>
                        <td>@stock.TotalCost</td>
                        <td>@stock.CreatedAt</td>
                        
                    </tr>
                }
            </tbody>
        </table>
    }

        <nav class="col-md-3 col-lg-2 d-md-block bg-light sidebar pt-3 border-end" style="min-height: 100vh;">
            <partial name="_AdminNav" />
        </nav>

        <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 pt-3">

            <div>
                <h2 style="display:inline-block">Quản lý Kho</h2>
                <a asp-controller="StockManagement" asp-action="AddNewStock" style="float:right; margin-top:10px;">Tạo đơn nhập hàng</a>
            </div>
            @if (Model == null || Model.Count == 0)
            {
                <p>Không có sản phẩm nào trong hệ thống.</p>
            }
            else
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>Nhà cung cấp</th>
                            <th>Giá</th>
                            <th>Ngày</th>

                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var stock in Model)
                        {
                            <tr>
                                <td><a asp-controller="StockManagement" asp-action="StockDetails" asp-route-id="@stock.Id">@stock.SupplierName</a></td>
                                <td>@stock.TotalCost</td>
                                <td>@stock.CreatedAt</td>

                            </tr>
                        }
                    </tbody>
                </table>
            }
        </main>

    </div>
</div>