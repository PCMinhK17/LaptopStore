@model List<ImportReceipt>
@using LaptopStore.Models

@{
    ViewData["Title"] = "Đơn nhập hàng";

}
<html>
<body>
    <div>
        <h2 style="display:inline-block">Các đơn nhập hàng</h2>
        <a asp-controller="StockManagement" asp-action="AddNewStockInOrder" style="float:right; margin-top:10px;">Tạo đơn nhập hàng</a>
    </div>
    @if (Model == null || Model.Count == 0)
    {
        <p>Không có sản phẩm nào trong hệ thống.</p>
    }
    else
    {
        <table class="table">
            <thead>
                <tr>
                    <th>Nhà cung cấp</th>
                    <th>Giá</th>
                    <th>Ngày</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var stock in Model)
                {
                    <tr>
                        <td><a asp-controller="StockManagement" asp-action="StockDetails" asp-route-id="@stock.Id">@stock.SupplierName</a></td>
                        <td>@stock.TotalCost</td>
                        <td>@stock.CreatedAt</td>
                        <td>@stock.Status</td>
                    </tr>
                }
            </tbody>
        </table>
        <!-- Phân trang -->
        <nav aria-label="Page navigation">
            <ul class="pagination">
                @if (ViewBag.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)">Trước</a>
                    </li>
                }
                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                    </li>
                }
                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)">Tiếp</a>
                    </li>
                }
            </ul>
        </nav>
    }

</body>
</html>