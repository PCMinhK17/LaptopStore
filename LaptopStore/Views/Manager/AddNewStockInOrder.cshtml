<div class="container mt-5">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Đơn nhập hàng mới</h5>
        </div>
        <div class="card-body">
            <div class="row g-4">
                <div class="col-md-6">
                    <label for="input-supplier-name" class="form-label fw-bold">Nhà cung cấp <span class="text-danger">*</span></label>
                    <input id="input-supplier-name" class="form-control" placeholder="Nhập tên nhà cung cấp..." />
                </div>

                <div class="col-md-6">
                    <label class="form-label fw-bold">Nhân viên phụ trách <span class="text-danger">*</span></label>
                    <select id="input-staff-id" class="form-select">
                        <option value="" selected disabled>-- Chọn nhân viên --</option>
                        @if (ViewBag.Staffs != null)
                        {
                            foreach (var staff in ViewBag.Staffs)
                            {
                                <option value="@staff.Id">@staff.FullName</option>
                            }
                        }
                    </select>
                </div>
            </div>

            <hr>

            <div class="position-relative">
                <div class="input-group mb-3">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" id="productInput" class="form-control form-control-lg"
                           placeholder="Nhập tên sản phẩm để tìm kiếm..." oninput="searchProduct()" onfocus="showSearch()">
                </div>
                <ul id="searchResult" class="list-group position-absolute w-100 shadow-lg d-none"
                    style="z-index: 1000; max-height: 300px; overflow-y: auto;" onmousedown="handleMouseDown()">
                </ul>
            </div>

            <div id="selectedContainer" class="row row-cols-1 g-3">
                <div class="col-12 text-center text-muted py-5" id="emptyNote">
                    <p>Chưa có sản phẩm nào được chọn.</p>
                </div>
            </div>

            <div class="mt-4 text-end">
                <button class="btn btn-primary btn-lg px-5" onclick="submitData()">Tạo đơn</button>
            </div>
        </div>
    </div>
</div>

<script>
    var allProducts = @Html.Raw(Json.Serialize(ViewBag.Products));
    let selectedList = [];

    let filtered = [];
    const productInput = document.getElementById('productInput');
    const resultPanel = document.getElementById('searchResult');

    searchProduct();

    let isClickingResult = false;

    function handleMouseDown() {
        isClickingResult = true;
    }

    function getProductImage(product) {
        // if (product.productImages && product.productImages.length > 0) {
        //     return product.productImages[0].imageUrl;
        // }
        return '/images/dell-xps-13-9350-2024-1731577899.png';
    }

    function showSearch() {
        if (filtered.length > 0) {
            resultPanel.classList.remove('d-none');
        }
    }

    document.addEventListener('mousedown', function (event) {
        const isClickInsideInput = productInput.contains(event.target);
        const isClickInsidePanel = resultPanel.contains(event.target);

        if (!isClickInsideInput && !isClickInsidePanel) {
            resultPanel.classList.add('d-none');
        }
    });

    function searchProduct() {
        const productInputValue = productInput.value.trim().toLowerCase();

        if (productInputValue.length < 1) {
            filtered = allProducts;
        } else {
            filtered = allProducts.filter(p => p.name.toLowerCase().includes(productInputValue));
        }

        if (filtered.length > 0) {
            resultPanel.innerHTML = filtered.map(p => `
                <li class="list-group-item list-group-item-action d-flex align-items-center"
                    style="cursor:pointer" onclick="addProduct(${p.id})">
                    <img src="${getProductImage(p)}" alt="" class="rounded me-3" style="width: 50px; height: 50px; object-fit: cover;">
                    <div class="flex-grow-1">
                        <div class="d-flex justify-content-between">
                            <strong>${p.name}</strong>
                            <span class="text-danger fw-bold">${p.price.toLocaleString()}đ</span>
                        </div>
                        <small class="text-muted">SKU: ${p.sku || 'N/A'} | Thương hiệu: ${p.brandName || 'N/A'}</small>
                    </div>
                </li>
            `).join('');
        } else {
            resultPanel.classList.add('d-none');
        }
    }

    function addProduct(id) {
        const product = allProducts.find(p => p.id === id);
        if (!product) return;

        const existing = selectedList.find(item => item.id === id);

        if (existing) {
            if (existing.quantity < 999) {
                existing.quantity += 1;
            }
        } else {
            selectedList.push({ ...product, quantity: 1 });
        }

        document.getElementById('productInput').value = '';
        resultPanel.classList.add('d-none');
        renderCards();
    }

    function updateQuantity(id, delta) {
        const item = selectedList.find(p => p.id === id);
        if (item) {
            item.quantity = Math.min(999, Math.max(1, item.quantity + delta));
            document.getElementById(`${id}-quantity`).value = item.quantity;
            document.getElementById(`${id}-total`).innerText = (item.price * item.quantity).toLocaleString() + 'đ';
        }
    }

    function removeItem(id) {
        selectedList = selectedList.filter(p => p.id !== id);
        renderCards();
    }

    function renderCards() {
        const container = document.getElementById('selectedContainer');

        container.className = "d-flex flex-column gap-2";

        if (selectedList.length === 0) {
            container.innerHTML = `
                <div class="text-center text-muted py-5 border rounded bg-light">
                    <p class="mb-0">Chưa có sản phẩm nào được chọn.</p>
                </div>`;
            return;
        }

        container.innerHTML = selectedList.map(item => `
            <div class="card shadow-sm border-start border-primary border-1">
                <div class="card-body py-2">
                    <div class="row align-items-center">
                        <div class="col-auto">
                            <img src="${getProductImage(item)}" class="rounded" style="width: 60px; height: 60px; object-fit: cover;">
                        </div>

                        <div class="col">
                            <h6 class="mb-0 fw-bold">${item.name}</h6>
                            <small class="text-muted">SKU: ${item.sku || 'N/A'}</small>
                        </div>

                        <div class="col-md-2 text-center">
                            <span class="text-danger fw-bold">${item.price.toLocaleString()}đ</span>
                            <div class="small text-muted">Đơn giá</div>
                        </div>

                        <div class="col-md-3">
                            <div class="input-group input-group-sm justify-content-center">
                                <button type="button" class="btn btn-outline-secondary" onclick="updateQuantity(${item.id}, -1)">-</button>
                                <input id="${item.id}-quantity" type="text" class="form-control text-center bg-white fw-bold" style="max-width: 60px" value="${item.quantity}"
                                    onkeypress="return event.charCode >= 48 && event.charCode <= 57"
                                    oninput="this.value = this.value.replace(/[^0-9]/g, ''); handleInputQuantity(${item.id}, this)">
                                <button type="button" class="btn btn-outline-secondary" onclick="updateQuantity(${item.id}, 1)">+</button>
                            </div>
                        </div>

                        <div class="col-md-2 text-end">
                            <div id="${item.id}-total" class="fw-bold text-dark">${(item.price * item.quantity).toLocaleString()}đ</div>
                            <button type="button" class="btn btn-link btn-sm text-danger p-0 border-0" onclick="removeItem(${item.id})">
                                <i class="bi bi-trash"></i> Xóa
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        `).join('');
    }

    function handleInputQuantity(id, element) {
        let val = element.value;

        if (val === '') {
            element.value = 1;
            return;
        } else {
            val = parseInt(val);
            val = Math.min(999, Math.max(1, val));
            element.value = val;
        }

        const item = selectedList.find(p => p.id === id);
        if (item) {
            item.quantity = parseInt(val);
            document.getElementById(`${id}-total`).innerText = (item.price * item.quantity).toLocaleString() + 'đ';
        }
    }

    async function submitData() {

        const supplierName = document.getElementById('input-supplier-name').value.trim();
        const staffId = document.getElementById('input-staff-id').value;

        if (!supplierName) {
            alert("Vui lòng nhập tên nhà cung cấp!");
            return;
        }
        if (!staffId) {
            alert("Vui lòng chọn nhân viên phụ trách!");
            return;
        }
        if (selectedList.length === 0) {
            alert("Vui lòng chọn ít nhất một sản phẩm!");
            return;
        }

        const orderData = {
            supplierName: supplierName,
            staffId: parseInt(staffId),
            items: selectedList.map(item => ({
                productId: item.id,
                quantity: item.quantity
            }))
        };

        console.log("Dữ liệu gửi đi:", orderData);

        try {
            const response = await fetch('/StockManagement/AddNewStockInOrder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(orderData)
            });

            if (response.ok) {
                alert("Tạo đơn hàng thành công!");
                window.location.href = "/StockManagement/Index";
            } else {
                alert("Có lỗi xảy ra khi tạo đơn.");
            }
        } catch (error) {
            console.error("Lỗi:", error);
        }
    }
</script>