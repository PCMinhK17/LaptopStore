@model List<ProductResponse>

<div class="d-flex justify-content-between align-items-center pb-2 mb-3 border-bottom">
    <h2 class="m-0">Quản lý sản phẩm</h2>
    <a asp-controller="ProductManagement" asp-action="AddNewProduct" class="btn btn-primary">
        + Thêm sản phẩm mới
    </a>
</div>

@if (Model == null || Model.Count == 0)
{
    <div class="d-flex flex-column justify-content-center align-items-center" style="min-height: 60vh;">
        <div class="text-center">
            <i class="bi bi-box-seam text-muted" style="font-size: 4rem;"></i>
            <h3 class="mt-3 text-muted">Không có sản phẩm nào trong hệ thống</h3>
            <p class="text-secondary">Vui lòng thêm sản phẩm mới để bắt đầu quản lý.</p>
            <a asp-controller="ProductManagement" asp-action="AddNewProduct" class="btn btn-primary mt-2">
                + Thêm sản phẩm ngay
            </a>
        </div>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Thumbnail</th>
                    <th>Tên sản phẩm</th>
                    <th>Phân loại</th>
                    <th>Thương hiệu</th>
                    <th>Giá bán</th>
                    <th>Số lượng</th>
                    <th>Trạng thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>
                            <img style="width:3rem; object-fit: cover;" class="rounded"
                                 src="@product.ProductImages.FirstOrDefault(i => i.IsThumbnail)?.ImageUrl"
                                 alt="@product.Name" />
                        </td>
                        <td>
                            <a asp-controller="ProductManagement" asp-action="ProductDetails" asp-route-id="@product.Id" class="text-decoration-none fw-bold">
                                @product.Name
                            </a>
                        </td>
                        <td>@product.CategoryName</td>
                        <td>@product.BrandName</td>
                        <td>@String.Format("{0:N0}đ", product.Price)</td>
                        <td>
                            <span class="badge @(product.StockQuantity > 0 ? "bg-success" : "bg-danger")">
                                @product.StockQuantity
                            </span>
                        </td>
                        <td>
                            @if (product.IsActive.Value)
                            {
                                <span class="text-success">Hiện</span>
                            }
                            else
                            {
                                <span class="text-secondary">Ẩn</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}