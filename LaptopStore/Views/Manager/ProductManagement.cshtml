@using LaptopStore.Models
@model PaginatedList<LaptopStore.DTOs.ProductDTOs.ProductResponse>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
    ViewData["Subtitle"] = "Quản lý danh sách sản phẩm trong hệ thống";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- Page Header -->
<div class="page-header">
    <div class="page-header-left">
        <h2>Danh sách sản phẩm</h2>
        <p>Quản lý kho hàng và thông tin sản phẩm</p>
    </div>
    <a asp-controller="ProductManagement" asp-action="AddNewProduct" class="btn btn-primary">
        <i class="fas fa-plus"></i>
        Thêm sản phẩm mới
    </a>
</div>

<!-- Filters Card -->
<div class="card mb-4">
    <form class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-12 col-md-4 col-lg-3">
                <label class="form-label">Tìm kiếm</label>
                <div class="search-input">
                    <i class="fas fa-search"></i>
                    <input type="text" name="searchString" class="form-control" value="@ViewBag.SearchString" placeholder="Tên sản phẩm, SKU...">
                </div>
            </div>
            <div class="col-6 col-md-3 col-lg-2">
                <label class="form-label">Phân loại</label>
                <select name="categoryId" asp-items="ViewBag.Categories" class="form-control form-select" onchange="this.form.submit()">
                    <option value="0">Tất cả</option>
                </select>
            </div>
            <div class="col-6 col-md-3 col-lg-2">
                <label class="form-label">Thương hiệu</label>
                <select name="brandId" asp-items="ViewBag.Brands" class="form-control form-select" onchange="this.form.submit()">
                    <option value="0">Tất cả</option>
                </select>
            </div>
            <div class="col-6 col-md-3 col-lg-2">
                <label class="form-label">Trạng thái</label>
                <select name="status" asp-items="ViewBag.StatusList" class="form-control form-select" onchange="this.form.submit()">
                </select>
            </div>
            <div class="col-6 col-md-3 col-lg-1">
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-search me-1"></i> Tìm
                </button>
            </div>
            <div class="col-6 col-md-3 col-lg-2">
                <a asp-action="ResetFilter" class="btn btn-secondary w-75">
                    <i class="fas fa-redo me-1"></i> Đặt lại
                </a>
            </div>
        </div>
    </form>
</div>

<!-- Products Table -->
<div class="card">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="fas fa-box-open"></i>
            Sản phẩm trong kho
            <span class="badge badge-light ms-2">@Model?.TotalItems tổng</span>
        </h5>
        <div class="d-flex gap-2">
            <a href="@Url.Action("ExportExcel")" class="btn btn-sm btn-secondary">
                <i class="fas fa-file-excel"></i>
                <span class="d-none d-md-inline ms-1">Xuất Excel</span>
            </a>
        </div>
    </div>
    
    <div class="table-container">
        @if (Model == null || Model.Count == 0)
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <i class="fas fa-box-open"></i>
                </div>
                <div class="empty-state-title">Chưa có sản phẩm nào</div>
                <p class="empty-state-text">Bắt đầu thêm sản phẩm vào hệ thống</p>
                <a asp-action="AddNewProduct" class="btn btn-primary">
                    <i class="fas fa-plus me-1"></i> Thêm sản phẩm đầu tiên
                </a>
            </div>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th style="width: 50px;">STT</th>
                        <th>Sản phẩm</th>
                        <th>Danh mục</th>
                        <th>Thương hiệu</th>
                        <th>Giá bán</th>
                        <th>Tồn kho</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @{ 
                        int stt = (Model.PageIndex - 1) * 10 + 1;
                    }
                    @foreach (var product in Model)
                    {
                        var stockClass = product.StockQuantity > 10 ? "badge-success" : 
                                         product.StockQuantity > 0 ? "badge-warning" : "badge-danger";
                        var stockIcon = product.StockQuantity > 10 ? "fa-check-circle" : 
                                        product.StockQuantity > 0 ? "fa-exclamation-triangle" : "fa-times-circle";
                        var stockText = product.StockQuantity > 0 ? product.StockQuantity.ToString() : "Hết hàng";
                        
                        <tr class="product-row" 
                            data-category="@product.CategoryName" 
                            data-brand="@product.BrandName" 
                            data-status="@(product.IsActive == true ? "active" : "inactive")"
                            data-stock="@(product.StockQuantity <= 5 ? "lowstock" : "instock")">
                            <td class="text-center fw-medium">@(stt++)</td>
                            <td>
                                <div class="table-product">
                                    <div class="table-product-img">
                                        <img src="@(product.ProductImages?.FirstOrDefault(i => i.IsThumbnail)?.ImageUrl ?? "/images/default-product.png")" 
                                             alt="@product.Name" />
                                    </div>
                                    <div class="table-product-info">
                                        <a asp-action="ProductDetails" asp-route-id="@product.Id" 
                                           class="table-product-name" style="text-decoration: none; color: var(--text-primary);">
                                            @product.Name
                                        </a>
                                        <div class="table-product-sku">SKU: @product.Sku</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge badge-light">@product.CategoryName</span>
                            </td>
                            <td>@product.BrandName</td>
                            <td>
                                <span class="fw-bold text-primary">@product.Price.ToString("#,##0") ₫</span>
                            </td>
                            <td>
                                <span class="badge @stockClass">
                                    <i class="fas @stockIcon me-1"></i>
                                    @stockText
                                </span>
                            </td>
                            <td>
                                <span class="badge @(product.IsActive == true ? "badge-success" : "badge-danger")">
                                    <span class="status-dot @(product.IsActive == true ? "active" : "inactive") me-1"></span>
                                    @(product.IsActive == true ? "Đang bán" : "Ngừng bán")
                                </span>
                            </td>
                            <td class="text-end">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="ProductDetails" asp-route-id="@product.Id" 
                                       class="btn btn-icon btn-sm btn-secondary" title="Xem chi tiết">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="UpdateProduct" asp-route-id="@product.Id" class="btn btn-icon btn-sm btn-secondary" title="Chỉnh sửa">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
    
    @if (Model != null && Model.Count > 0)
    {
        <div class="card-footer">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div class="pagination-info">
                    Hiển thị <strong>@Model.Count</strong> trên tổng số <strong>@Model.TotalItems</strong> sản phẩm
                </div>
                <div class="pagination">
                    @if (Model.HasPreviousPage)
                    {
                        <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex - 1)" class="pagination-btn">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    }
                    else
                    {
                        <span class="pagination-btn disabled">
                            <i class="fas fa-chevron-left"></i>
                        </span>
                    }
                    
                    @for (int i = 1; i <= Model.TotalPages && i <= 5; i++)
                    {
                        <a asp-action="Index" 
                           asp-route-pageNumber="@i"
                           class="pagination-btn @(i == Model.PageIndex ? "active" : "")">
                            @i
                        </a>
                    }
                    
                    @if (Model.TotalPages > 5)
                    {
                        <span class="pagination-btn disabled">...</span>
                        <a asp-action="Index" 
                           asp-route-pageNumber="@Model.TotalPages"
                           class="pagination-btn @(Model.TotalPages == Model.PageIndex ? "active" : "")">
                            @Model.TotalPages
                        </a>
                    }
                    
                    @if (Model.HasNextPage)
                    {
                        <a asp-action="Index" asp-route-pageNumber="@(Model.PageIndex + 1)" class="pagination-btn">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    }
                    else
                    {
                        <span class="pagination-btn disabled">
                            <i class="fas fa-chevron-right"></i>
                        </span>
                    }
                </div>
            </div>
        </div>
    }
</div>