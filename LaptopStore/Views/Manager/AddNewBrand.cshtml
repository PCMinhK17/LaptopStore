@model LaptopStore.DTOs.BrandDTOs.AddNewBrandRequest

<div class="card shadow-sm border-0">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center py-3">
        <h4 class="mb-0">Thêm thương hiệu mới</h4>
        <a asp-controller="BrandManagement" asp-action="Index"
           class="btn btn-sm btn-light text-primary fw-bold">
            <i class="bi bi-arrow-left"></i> Trở về danh sách
        </a>
    </div>

    <div class="card-body bg-light rounded-bottom">

        <form asp-controller="BrandManagement"
              asp-action="AddNewBrand"
              method="post"
              enctype="multipart/form-data"
              class="bg-white p-4 rounded border">

            <div class="row g-4">

                <div class="col-md-6">
                    <label asp-for="Name" class="form-label fw-bold">
                        Tên thương hiệu <span class="text-danger">*</span>
                    </label>
                    <input asp-for="Name" class="form-control"
                           placeholder="Ví dụ: Dell, Asus, MSI..." />
                    <span asp-validation-for="Name"
                          class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Origin" class="form-label fw-bold">
                        Quốc gia<span class="text-danger">*</span>
                    </label>
                    <input asp-for="Origin" class="form-control"
                           placeholder="Ví dụ: USA, Taiwan..." />
                </div>

                <div class="col-md-12">
                    <label class="form-label fw-bold">
                        Logo thương hiệu
                    </label>

                    <div class="input-group">
                        <input asp-for="LogoFile"
                               type="file"
                               class="form-control"
                               id="uploadLogo"
                               accept="image/*">

                        <label class="input-group-text bg-primary text-white border-primary"
                               for="uploadLogo">
                            Tải lên
                        </label>
                    </div>
                </div>

               

                <div class="col-12 mt-5 pt-3 border-top text-end">
                    <a asp-controller="BrandManagement"
                       asp-action="Index"
                       class="btn btn-outline-secondary me-2 px-4">
                        Hủy
                    </a>

                    <button type="submit"
                            class="btn btn-primary px-5 fw-bold">
                        Lưu thương hiệu
                    </button>
                </div>

            </div>

        </form>
    </div>
</div>
