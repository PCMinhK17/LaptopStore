@model LaptopStore.Models.Category

@{
    ViewData["Title"] = "Quản lý phân loại";
    ViewData["Subtitle"] = "Chi tiết phân loại";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4 mb-5">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Chi tiết phân loại</h2>
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mt-3">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mt-3">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        <div class="d-flex gap-2">
            <a asp-controller="CategoryManagement"
               asp-action="Index"
               class="btn btn-outline-secondary">
                ← Quay lại danh sách
            </a>

            <a asp-controller="CategoryManagement"
               asp-action="UpdateCategory"
               asp-route-id="@Model.Id"
               class="btn btn-primary">
                Cập nhật phân loại
            </a>

            <button class="btn btn-danger"
                    data-bs-toggle="modal"
                    data-bs-target="#deleteCategoryModal">
                Xóa phân loại
            </button>
        </div>
    </div>


    <!-- CATEGORY INFO CARD -->
    <div class="card shadow-sm">
        <div class="card-body p-4">
            <div class="row">

                <div class="col-md-12">
                    <h4 class="mb-4">@Model.Name</h4>

                    <table class="table table-borderless">
                        <tr>
                            <td class="text-muted" style="width: 180px;">
                                Mô tả
                            </td>
                            <td>
                                @(string.IsNullOrEmpty(Model.Description)
                                                                ? "-"
                                                                : Model.Description)
                            </td>
                        </tr>

                        

                        <tr>
                            <td class="text-muted">
                                Tổng số sản phẩm
                            </td>
                            <td>
                                @(Model.Products?.Count ?? 0)
                            </td>
                        </tr>
                    </table>
                </div>

            </div>
        </div>
    </div>


    <!-- PRODUCT LIST -->
    @if (Model.Products != null && Model.Products.Any())
    {
        <div class="mt-5">
            <h4 class="mb-4">
                Sản phẩm thuộc phân loại này
            </h4>

            <div class="row g-4">
                @foreach (var product in Model.Products)
                {
                    var thumbnail = product.ProductImages?
                    .FirstOrDefault(i => i.IsThumbnail == true)?.ImageUrl
                    ?? product.ProductImages?.FirstOrDefault()?.ImageUrl
                    ?? "/images/no-image.png";

                    <div class="col-md-3">
                        <div class="card h-100 shadow-sm">

                            <img src="@thumbnail"
                                 class="card-img-top p-3"
                                 style="height: 180px; object-fit: contain;" />

                            <div class="card-body">
                                <h6 class="card-title text-truncate">
                                    @product.Name
                                </h6>

                                <p class="text-danger fw-bold mb-2">
                                    @String.Format("{0:N0} VND", product.Price)
                                </p>

                                <a asp-controller="Product"
                                   asp-action="Detail"
                                   asp-route-id="@product.Id"
                                   class="btn btn-sm btn-outline-primary w-100">
                                    Xem chi tiết
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="mt-5">
            <div class="alert alert-warning">
                Phân loại này chưa có sản phẩm nào.
            </div>
        </div>
    }

</div>



<!-- DELETE CATEGORY MODAL -->
<div class="modal fade"
     id="deleteCategoryModal"
     tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">
                    Xác nhận xóa
                </h5>
                <button type="button"
                        class="btn-close btn-close-white"
                        data-bs-dismiss="modal">
                </button>
            </div>

            <div class="modal-body">
                Bạn có chắc chắn muốn xóa phân loại
                <strong class="text-danger">
                    @Model.Name
                </strong> ?
                <br />
                <small class="text-muted">
                    Hành động này không thể hoàn tác.
                </small>
            </div>

            <div class="modal-footer">
                <form asp-controller="CategoryManagement"
                      asp-action="DeleteCategory"
                      method="post">

                    <input type="hidden"
                           name="id"
                           value="@Model.Id" />

                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Hủy
                    </button>

                    <button type="submit"
                            class="btn btn-danger">
                        Xóa
                    </button>
                </form>
            </div>

        </div>
    </div>
</div>
