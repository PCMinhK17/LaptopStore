<!-- Toast Notification Element -->
<div class="home-toast" id="homeToast">
    <i class="fas fa-check-circle"></i>
    <span id="homeToastText"></span>
</div>

@section Scripts {
    <script>
        // ====== Toast Notification ======
        function showToast(message, type) {
            var toast = document.getElementById('homeToast');
            var toastText = document.getElementById('homeToastText');
            var toastIcon = toast.querySelector('i');

            toastText.textContent = message;
            toast.className = 'home-toast ' + type;

            if (type === 'success') {
                toastIcon.className = 'fas fa-check-circle';
            } else if (type === 'error') {
                toastIcon.className = 'fas fa-exclamation-circle';
            } else {
                toastIcon.className = 'fas fa-info-circle';
            }

            setTimeout(function() {
                toast.classList.add('show');
            }, 10);

            setTimeout(function() {
                toast.classList.remove('show');
            }, 3000);
        }

        // ====== Quantity Control ======
        function changeQty(productId, delta) {
            var input = document.getElementById('qty-' + productId);
            var currentVal = parseInt(input.value) || 1;
            var maxVal = parseInt(input.max) || 99;
            var newVal = currentVal + delta;

            if (newVal < 1) newVal = 1;
            if (newVal > maxVal) newVal = maxVal;

            input.value = newVal;

            // Update button states
            var container = input.closest('.quantity-selector');
            var buttons = container.querySelectorAll('.quantity-btn');
            buttons[0].disabled = (newVal <= 1);
            buttons[1].disabled = (newVal >= maxVal);
        }

        function validateQty(productId, maxQty) {
            var input = document.getElementById('qty-' + productId);
            var val = parseInt(input.value) || 1;
            if (val < 1) val = 1;
            if (val > maxQty) val = maxQty;
            input.value = val;
        }

        // ====== Add to Cart (AJAX) ======
        function addToCart(productId) {
            var isAuthenticated = @(isAuthenticated.ToString().ToLower());
            if (!isAuthenticated) {
                window.location.href = '@Url.Action("Login", "Account")?returnUrl=' + encodeURIComponent(window.location.pathname);
                return;
            }

            var quantity = parseInt(document.getElementById('qty-' + productId).value) || 1;
            var btn = document.getElementById('cart-btn-' + productId);
            var originalHtml = btn.innerHTML;

            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Đang thêm...';

            var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            $.ajax({
                url: '@Url.Action("AddToCartAjax", "Cart")',
                type: 'POST',
                data: {
                    productId: productId,
                    quantity: quantity,
                    __RequestVerificationToken: token
                },
                success: function(response) {
                    if (response.success) {
                        btn.innerHTML = '<i class="fas fa-check"></i> Đã thêm!';
                        btn.classList.add('added');
                        showToast(response.message, 'success');

                        // Update cart badge in header
                        updateCartBadge(response.cartItemCount);

                        // Reset button after delay
                        setTimeout(function() {
                            btn.innerHTML = originalHtml;
                            btn.classList.remove('added');
                            btn.disabled = false;
                            // Reset quantity
                            var input = document.getElementById('qty-' + productId);
                            input.value = 1;
                            var container = input.closest('.quantity-selector');
                            var buttons = container.querySelectorAll('.quantity-btn');
                            buttons[0].disabled = true;
                            buttons[1].disabled = false;
                        }, 2000);
                    } else {
                        if (response.requireLogin) {
                            window.location.href = '@Url.Action("Login", "Account")?returnUrl=' + encodeURIComponent(window.location.pathname);
                        } else {
                            showToast(response.message, 'error');
                            btn.innerHTML = originalHtml;
                            btn.disabled = false;
                        }
                    }
                },
                error: function() {
                    showToast('Có lỗi xảy ra, vui lòng thử lại', 'error');
                    btn.innerHTML = originalHtml;
                    btn.disabled = false;
                }
            });
        }

        // ====== Buy Now (AJAX + Redirect) ======
        function buyNow(productId) {
            var isAuthenticated = @(isAuthenticated.ToString().ToLower());
            if (!isAuthenticated) {
                window.location.href = '@Url.Action("Login", "Account")?returnUrl=' + encodeURIComponent(window.location.pathname);
                return;
            }

            var quantity = parseInt(document.getElementById('qty-' + productId).value) || 1;
            var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            $.ajax({
                url: '@Url.Action("AddToCartAjax", "Cart")',
                type: 'POST',
                data: {
                    productId: productId,
                    quantity: quantity,
                    __RequestVerificationToken: token
                },
                success: function(response) {
                    if (response.success) {
                        window.location.href = '@Url.Action("CartView", "Cart")';
                    } else {
                        if (response.requireLogin) {
                            window.location.href = '@Url.Action("Login", "Account")?returnUrl=' + encodeURIComponent(window.location.pathname);
                        } else {
                            showToast(response.message, 'error');
                        }
                    }
                },
                error: function() {
                    showToast('Có lỗi xảy ra, vui lòng thử lại', 'error');
                }
            });
        }

        // ====== Toggle Wishlist (AJAX) ======
        function toggleWishlist(productId, btn) {
            var isAuthenticated = @(isAuthenticated.ToString().ToLower());
            if (!isAuthenticated) {
                window.location.href = '@Url.Action("Login", "Account")?returnUrl=' + encodeURIComponent(window.location.pathname);
                return;
            }

            var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

            $.ajax({
                url: '@Url.Action("Toggle", "Wishlist")',
                type: 'POST',
                data: {
                    productId: productId,
                    __RequestVerificationToken: token
                },
                success: function(response) {
                    if (response.success) {
                        var icon = btn.querySelector('i');
                        if (response.isInWishlist) {
                            btn.classList.add('active');
                            icon.className = 'fas fa-heart';
                            btn.title = 'Bỏ yêu thích';
                        } else {
                            btn.classList.remove('active');
                            icon.className = 'far fa-heart';
                            btn.title = 'Thêm yêu thích';
                        }

                        showToast(response.message, 'success');

                        // Update wishlist badge in header
                        updateWishlistBadge(response.wishlistCount);
                    } else {
                        if (response.requireLogin) {
                            window.location.href = '@Url.Action("Login", "Account")?returnUrl=' + encodeURIComponent(window.location.pathname);
                        } else {
                            showToast(response.message, 'error');
                        }
                    }
                },
                error: function() {
                    showToast('Có lỗi xảy ra, vui lòng thử lại', 'error');
                }
            });
        }

        // ====== Update Header Badges ======
        function updateCartBadge(count) {
            var badge = document.getElementById('cartBadgeCount');
            if (badge) {
                badge.textContent = count;
                badge.style.display = count > 0 ? 'flex' : 'none';
            }
        }

        function updateWishlistBadge(count) {
            var badge = document.getElementById('wishlistBadgeCount');
            if (badge) {
                badge.textContent = count;
                badge.style.display = count > 0 ? 'flex' : 'none';
            }
        }


    </script>
}
