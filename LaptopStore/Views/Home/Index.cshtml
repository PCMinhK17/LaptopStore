@using LaptopStore.Models
@{
    ViewData["Title"] = "Trang chủ";
    Layout = "_Layout";

    var featuredProducts = ViewBag.FeaturedProducts as List<Product> ?? new List<Product>();
    var brands = ViewBag.Brands as List<Brand> ?? new List<Brand>();
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
    var categoryProductCounts = ViewBag.CategoryProductCounts as Dictionary<int, int> ?? new Dictionary<int, int>();
    var wishlistProductIds = ViewBag.WishlistProductIds as List<int?> ?? new List<int?>();
    var cartItemCount = (int)(ViewBag.CartItemCount ?? 0);
    var wishlistCount = (int)(ViewBag.WishlistCount ?? 0);
    var isAuthenticated = User?.Identity?.IsAuthenticated ?? false;

    // Category icons mapping
    var categoryIcons = new Dictionary<string, string>(StringComparer.OrdinalIgnoreCase) {
        {"gaming", "fa-gamepad"}, {"game", "fa-gamepad"},
        {"văn phòng", "fa-briefcase"}, {"office", "fa-briefcase"},
        {"ultrabook", "fa-feather"}, {"mỏng nhẹ", "fa-feather"},
        {"đồ hoạ", "fa-palette"}, {"đồ họa", "fa-palette"}, {"design", "fa-palette"},
        {"sinh viên", "fa-graduation-cap"}, {"student", "fa-graduation-cap"},
        {"workstation", "fa-desktop"}, {"doanh nhân", "fa-user-tie"},
        {"laptop", "fa-laptop"}
    };
}

@section Styles {
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true" />
}

<!-- ===================== HERO BANNER ===================== -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="hero-content">
                    <h1 class="hero-title">Khám phá Laptop<br>cho mọi nhu cầu</h1>
                    <p class="hero-subtitle">
                        Cung cấp laptop chính hãng từ các thương hiệu hàng đầu thế giới.
                        Giá tốt nhất — Bảo hành toàn diện — Giao hàng tận nơi.
                    </p>
                    <div class="hero-buttons">
                        <a href="@Url.Action("Index", "Product")" class="hero-btn-primary">
                            <i class="fas fa-shopping-bag"></i> Mua ngay
                        </a>
                    </div>
                    <div class="hero-search">
                        <form class="hero-search-form" method="get" asp-controller="Product" asp-action="Search">
                            <input type="text" name="searchTerm" placeholder="Tìm kiếm laptop theo tên, hãng, cấu hình..." />
                            <button type="submit"><i class="fas fa-search"></i></button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block">
                <div class="hero-image-wrapper text-center">
                    <div id="heroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel" data-bs-interval="3000">
                        <div class="carousel-indicators">
                            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Slide 1"></button>
                            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
                            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
                        </div>
                        <div class="carousel-inner">
                            <div class="carousel-item active">
                                <img src="/images/dell-xps-13-9350-2024-1731577899.png" alt="Laptop Dell XPS" class="hero-laptop-img" style="max-height: 380px; object-fit: contain;" />
                            </div>
                            <div class="carousel-item">
                                <img src="/images/laptop-dell-xps-13-9350-black-6.webp" alt="Laptop Gaming" class="hero-laptop-img" style="max-height: 380px; filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.2)); border-radius: 12px; object-fit: contain;" />
                            </div>
                            <div class="carousel-item">
                                <img src="/images/53a61e0d-adaa-49e7-a590-022300851971_Dell-XPS-9310-i5-5-scaled.jpg" alt="Macbook Pro" class="hero-laptop-img" style="max-height: 380px; filter: drop-shadow(0 20px 40px rgba(0, 0, 0, 0.2)); border-radius: 12px; mix-blend-mode: multiply; object-fit: contain;" />
                            </div>
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon" aria-hidden="true" style="filter: invert(1) grayscale(100); mix-blend-mode: difference;"></span>
                            <span class="visually-hidden">Trang trước</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon" aria-hidden="true" style="filter: invert(1) grayscale(100); mix-blend-mode: difference;"></span>
                            <span class="visually-hidden">Trang sau</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ===================== BRAND SHOWCASE ===================== -->
<section class="brand-section">
    <div class="container">
        <div class="brand-grid">
            @foreach (var brand in brands)
            {
                <a href="@Url.Action("FilterByBrand", "Product", new { brandId = brand.Id })" class="brand-item" title="@brand.Name">
                    @if (!string.IsNullOrEmpty(brand.LogoUrl))
                    {
                        <img src="@brand.LogoUrl" alt="@brand.Name" />
                    }
                    else
                    {
                        @brand.Name
                    }
                </a>
            }
        </div>
    </div>
</section>

<!-- ===================== FEATURED PRODUCTS ===================== -->
<section class="section-padding">
    <div class="container">
        <h2 class="section-title">🔥 Sản phẩm nổi bật</h2>
        <p class="section-subtitle">Những mẫu laptop mới nhất, được yêu thích nhất</p>

        @if (featuredProducts.Any())
        {
            <div class="product-grid">
                @foreach (var product in featuredProducts)
                {
                    var productImage = product.ProductImages?.FirstOrDefault()?.ImageUrl ?? "/images/laptop-dell-xps-13-9350-black-6.webp";
                    var avgRating = product.Reviews?.Any() == true ? product.Reviews.Average(r => r.Rating ?? 0) : 0;
                    var reviewCount = product.Reviews?.Count ?? 0;
                    var hasDiscount = product.OldPrice.HasValue && product.OldPrice > product.Price;
                    var discountPercent = hasDiscount ? (int)Math.Round(100 - ((double)product.Price / (double)product.OldPrice.Value * 100)) : 0;
                    var isInWishlist = wishlistProductIds.Contains(product.Id);
                    var isInStock = product.StockQuantity.HasValue && product.StockQuantity > 0;
                    var maxQty = product.StockQuantity ?? 0;

                    <div class="product-card">
                        <div class="product-card-image">
                            <a href="@Url.Action("Detail", "Product", new { id = product.Id })">
                                <img src="@productImage" alt="@product.Name" loading="lazy" />
                            </a>
                            @if (hasDiscount)
                            {
                                <span class="product-badge">-@(discountPercent)%</span>
                            }
                            else if (product.CreatedAt.HasValue && (DateTime.Now - product.CreatedAt.Value).TotalDays < 30)
                            {
                                <span class="product-badge product-badge-new">Mới</span>
                            }
                            <button class="product-wishlist-btn @(isInWishlist ? "active" : "")"
                                    onclick="toggleWishlist(@product.Id, this)"
                                    title="@(isInWishlist ? "Bỏ yêu thích" : "Thêm yêu thích")">
                                <i class="@(isInWishlist ? "fas" : "far") fa-heart"></i>
                            </button>
                        </div>

                        <div class="product-card-body">
                            <span class="product-card-brand">@product.Brand?.Name</span>
                            <h3 class="product-card-name">
                                <a href="@Url.Action("Detail", "Product", new { id = product.Id })">@product.Name</a>
                            </h3>

                            <!-- Rating -->
                            <div class="product-card-rating">
                                <span class="stars">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        @if (i <= Math.Floor(avgRating))
                                        {
                                            <i class="fas fa-star"></i>
                                        }
                                        else if (i - avgRating < 1 && i - avgRating > 0)
                                        {
                                            <i class="fas fa-star-half-alt"></i>
                                        }
                                        else
                                        {
                                            <i class="far fa-star"></i>
                                        }
                                    }
                                </span>
                                <span class="rating-text">(@reviewCount đánh giá)</span>
                            </div>

                            <!-- Specs -->
                            <div class="product-card-specs">
                                @if (!string.IsNullOrEmpty(product.Cpu))
                                {
                                    <span><i class="fas fa-microchip"></i> @product.Cpu</span>
                                }
                                @if (!string.IsNullOrEmpty(product.Ram))
                                {
                                    <span><i class="fas fa-memory"></i> @product.Ram</span>
                                }
                            </div>

                            <!-- Price -->
                            <div class="product-card-price">
                                @if (hasDiscount)
                                {
                                    <span class="product-old-price">@String.Format("{0:N0}đ", product.OldPrice)</span>
                                }
                                <span class="product-current-price">@String.Format("{0:N0}đ", product.Price)</span>
                            </div>
                        </div>

                        <div class="product-card-footer">
                            @if (isInStock)
                            {
                                <!-- Quantity Selector -->
                                <div class="quantity-selector" data-product-id="@product.Id" data-max="@maxQty">
                                    <button type="button" class="quantity-btn" onclick="changeQty(@product.Id, -1)" disabled>
                                        <i class="fas fa-minus"></i>
                                    </button>
                                    <input type="number" class="quantity-input" id="qty-@product.Id" value="1" min="1" max="@maxQty"
                                           onchange="validateQty(@product.Id, @maxQty)" readonly />
                                    <button type="button" class="quantity-btn" onclick="changeQty(@product.Id, 1)" @(maxQty <= 1 ? "disabled" : "")>
                                        <i class="fas fa-plus"></i>
                                    </button>
                                </div>
                                <!-- Add to Cart / Buy Now -->
                                <div class="d-flex gap-2 mt-2">
                                    <button class="add-to-cart-btn flex-grow-1" id="cart-btn-@product.Id" onclick="addToCart(@product.Id)">
                                        <i class="fas fa-shopping-cart"></i> Giỏ hàng
                                    </button>
                                    <button class="buy-now-btn flex-grow-1" onclick="buyNow(@product.Id)">
                                        <i class="fas fa-bolt"></i> Mua ngay
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div class="out-of-stock-badge">
                                    <i class="fas fa-times-circle"></i> Hết hàng
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="text-center">
                <a href="@Url.Action("Index", "Product")" class="view-all-btn">
                    Xem tất cả sản phẩm <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="fas fa-box-open" style="font-size: 3rem; color: var(--text-secondary); margin-bottom: 16px;"></i>
                <p style="color: var(--text-secondary);">Hiện chưa có sản phẩm nào. Hãy quay lại sau!</p>
            </div>
        }
    </div>
</section>

<!-- ===================== SHOP BY CATEGORY ===================== -->
<section class="section-padding section-bg-light">
    <div class="container">
        <h2 class="section-title">📂 Mua theo danh mục</h2>
        <p class="section-subtitle">Chọn loại laptop phù hợp với nhu cầu của bạn</p>

        <div class="category-grid">
            @foreach (var cat in categories)
            {
                var iconClass = "fa-laptop";
                foreach (var kvp in categoryIcons)
                {
                    if (cat.Name?.ToLower().Contains(kvp.Key.ToLower()) == true)
                    {
                        iconClass = kvp.Value;
                        break;
                    }
                }
                var productCount = categoryProductCounts.ContainsKey(cat.Id) ? categoryProductCounts[cat.Id] : 0;

                <a href="@Url.Action("FilterByCategory", "Product", new { categoryId = cat.Id })" class="category-card">
                    <div class="category-icon">
                        <i class="fas @iconClass"></i>
                    </div>
                    <div class="category-name">@cat.Name</div>
                    <div class="category-count">@productCount sản phẩm</div>
                </a>
            }
        </div>
    </div>
</section>

