@model LaptopStore.Models.Product

@{
    ViewData["Title"] = "Chi tiết sản phẩm";
    var mainImage = Model.ProductImages?.FirstOrDefault()?.ImageUrl ?? "/images/no-image.png";
}

<div class="container mt-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <div class="row justify-content-center">
        <div class="col-md-12">
            <div class="card shadow-lg p-4">
                <div class="row g-4">
                    <!-- Thumbnails bên trái -->
                    <div class="col-md-1 d-flex flex-column align-items-center">
                        @if (Model.ProductImages != null && Model.ProductImages.Any())
                        {
                            foreach (var img in Model.ProductImages)
                            {
                                <img src="@img.ImageUrl"
                                     class="img-thumbnail mb-3 product-thumb"
                                     style="cursor:pointer; max-width:100px; max-height:70px;"
                                     onclick="showMainImage('@img.ImageUrl')" />
                            }
                        }
                    </div>
                    <!-- Ảnh lớn bên phải -->
                    <div class="col-md-6 d-flex align-items-center justify-content-center">
                        <img id="mainProductImage" src="@mainImage" alt="@Model.Name"
                             class="img-fluid rounded shadow"
                             style="max-height: 320px; object-fit: contain;" />
                    </div>
                    <!-- Thông tin sản phẩm bên phải -->
                    <div class="col-md-5">
                        <h3 class="card-title">@Model.Name</h3>
                        <p><strong>Thương hiệu:</strong> @Model.Brand?.Name</p>
                        <p><strong>CPU:</strong> @Model.Cpu</p>
                        <p><strong>GPU:</strong> @Model.Gpu</p>
                        <p><strong>Ram:</strong> @Model.Ram</p>
                        <p><strong>Ổ Cứng:</strong> @Model.HardDrive</p>
                        <p><strong>Màn Hình:</strong> @Model.ScreenSize</p>
                        <p><strong>Khối Lượng:</strong> @Model.Weight</p>
                        <p><strong>Mô tả:</strong> @Model.Description</p>
                        <p>
                            <strong>Giá:</strong> 
                            <span class="text-danger">@String.Format("{0:N0} VND", Model.Price)</span>
                        </p>
                        <p>
                            <strong>Số lượng:</strong>
                            @(Model.StockQuantity > 0 ? Model.StockQuantity.ToString() : Html.Raw("<span class='text-danger'>Hết hàng</span>"))
                        </p>
                        <!-- Nút thêm vào giỏ hàng -->
                        <form method="post" asp-controller="Cart" asp-action="AddToCart">
                            <input type="hidden" name="productId" value="@Model.Id" />
                            @if (Model.StockQuantity > 0)
                            {
                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-secondary w-100" disabled>
                                    <i class="bi bi-cart-x"></i> Hết hàng
                                </button>
                            }
                        </form>
                    </div>
                    <!-- Form đánh giá -->
                    <div class="row mt-4">
                        <p>
                            <h4>
                                Đánh giá trung bình:
                                <span class="text-warning">
                                    ⭐ @ViewBag.AvgRating / 5
                                </span>
                            </h4>
                        </p>
                        <div class="col-md-9">
                            <p>5⭐ (@ViewBag.Rating5)</p>
                            <p>4⭐ (@ViewBag.Rating4)</p>
                            <p>3⭐ (@ViewBag.Rating3)</p>
                            <p>2⭐ (@ViewBag.Rating2)</p>
                            <p>1⭐ (@ViewBag.Rating1)</p>
                        </div>
                    </div>

                    <h4>Viết đánh giá</h4>

                    <form method="post" asp-controller="Review" asp-action="CreateReview">

                        <input type="hidden" name="ProductId" value="@Model.Id" />

                        <div class="mb-3">
                            <label>Rating</label>
                            <select name="Rating" class="form-control">
                                <option value="5">⭐⭐⭐⭐⭐</option>
                                <option value="4">⭐⭐⭐⭐</option>
                                <option value="3">⭐⭐⭐</option>
                                <option value="2">⭐⭐</option>
                                <option value="1">⭐</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label>Comment</label>
                            <textarea name="Comment" class="form-control" maxlength="100" id="commentBox"></textarea>
                            <small id="charCount">0 / 100</small>
                        </div>

                        <button type="submit" class="btn btn-primary">
                            Gửi đánh giá
                        </button>

                    </form>
                    
                    <!--Danh sách đánh giá-->
                    @if (ViewBag.Reviews != null && ViewBag.Reviews.Count > 0)
                    {
                        <div class="mt-5">
                            
                            <h4>Đánh giá từ người dùng</h4>

                            @foreach (var review in ViewBag.Reviews)
                            {
                                <div class="border rounded p-3 mb-3 bg-light">
                                    <strong>@review.User?.FullName</strong>

                                    <span class="text-warning">
                                        @for (int i = 0; i < review.Rating; i++)
                                        {
                                            <span>★</span>
                                        }
                                    </span>

                                    <br />

                                    <small class="text-muted">
                                        @review.CreatedAt?.ToString("dd/MM/yyyy")
                                    </small>

                                    <p class="mt-2 mb-0">@review.Comment</p>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mt-4">Chưa có đánh giá nào cho sản phẩm này.</p>
                    }
                    @if (ViewBag.TotalPages > 1)
                    {
                        <nav class="mt-3">
                            <ul class="pagination justify-content-center">

                                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                                {
                                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                                        <a class="page-link"
                                           asp-action="Detail"
                                           asp-route-id="@Model.Id"
                                           asp-route-page="@i">
                                            @i
                                        </a>
                                    </li>
                                }

                            </ul>
                        </nav>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function showMainImage(url) {
            document.getElementById('mainProductImage').src = url;
        }
        document.getElementById("commentBox").addEventListener("input", function () {
        let length = this.value.length;
        document.getElementById("charCount").innerText = length + " / 100";
        });
    </script>
}

<style>
    .product-thumb:hover {
        border: 2px solid #007bff;
    }
</style>